{
  "name": "petello",
  "version": "0.0.0",
  "scripts": {
    "ng": "ng",
    "start": "ng serve",
    "build": "ng build",
    "watch": "ng build --watch --configuration development",
    "test": "ng test --watch=false",
    "test:watch": "ng test",
    "format": "oxfmt src/**/*.{ts,html}",
    "format:check": "oxfmt --check src/**/*.{ts,html}",
    "prepare": "husky",
    "e2e": "playwright test",
    "e2e:report": "playwright show-report",
    "storybook": "ng run petello:storybook",
    "build-storybook": "ng run petello:build-storybook"
  },
  "private": true,
  "packageManager": "npm@10.9.0",
  "dependencies": {
    "@angular/animations": "^21.2.0",
    "@angular/cdk": "^21.2.1",
    "@angular/common": "^21.2.0",
    "@angular/compiler": "^21.2.0",
    "@angular/core": "^21.2.0",
    "@angular/forms": "^21.2.0",
    "@angular/material": "^21.2.1",
    "@angular/platform-browser": "^21.2.0",
    "@angular/router": "^21.2.0",
    "@ngrx/effects": "^21.0.1",
    "@ngrx/entity": "^21.0.1",
    "@ngrx/store": "^21.0.1",
    "@ngrx/store-devtools": "^21.0.1",
    "rxjs": "~7.8.0",
    "tslib": "^2.3.0"
  },
  "devDependencies": {
    "@angular-devkit/build-angular": "^21.2.2",
    "@angular/build": "^21.2.1",
    "@angular/cli": "^21.2.1",
    "@angular/compiler-cli": "^21.2.0",
    "@commitlint/cli": "^20.4.3",
    "@commitlint/config-conventional": "^20.4.3",
    "@playwright/test": "^1.58.2",
    "@storybook/addon-a11y": "^10.2.17",
    "@storybook/angular": "^10.2.17",
    "@storybook/test": "^8.6.15",
    "husky": "^9.1.7",
    "jsdom": "^28.0.0",
    "oxfmt": "^0.38.0",
    "prettier": "^3.8.1",
    "storybook": "^10.2.17",
    "typescript": "~5.9.2",
    "vitest": "^4.0.8"
  }
}
